# Copy to .env and fill in for local development.
NODE_ENV=development
PORT=8000
DATABASE_URL=postgresql://postgres@localhost/newsful
TEST_DATABASE_URL=postgresql://postgres@localhost/newsful-test
# Required in production. Generate one with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY=7d
# Set to true when the database requires TLS (defaults to true in production)
# DATABASE_SSL=true
